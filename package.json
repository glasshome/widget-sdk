{
  "name": "@glasshome/widget-sdk",
  "version": "0.3.2",
  "description": "SDK for building GlassHome dashboard widgets with SolidJS",
  "keywords": [
    "glasshome",
    "widget",
    "sdk",
    "solidjs",
    "vite",
    "home-assistant",
    "dashboard",
    "smart-home"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "@glasshome/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schemas": {
      "@glasshome/source": "./src/schemas.ts",
      "types": "./dist/schemas.d.ts",
      "import": "./dist/schemas.js"
    },
    "./vite": {
      "@glasshome/source": "./src/vite/index.ts",
      "types": "./dist/vite/index.d.ts",
      "import": "./dist/vite/index.js"
    },
    "./tailwind-sources": "./tailwind-sources.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "preview",
    "tailwind-sources.css"
  ],
  "scripts": {
    "build": "vite build && tsc",
    "dev": "vite build --watch"
  },
  "peerDependencies": {
    "solid-js": "^1.9.11"
  },
  "dependencies": {
    "@modular-forms/solid": "^0.25.1",
    "@solid-primitives/resize-observer": "^2.1.5",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.2.2",
    "typescript": "^5",
    "vite": "^7.3.1",
    "vite-plugin-externalize-deps": "^0.8.0",
    "vite-plugin-solid": "^2.11.10"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/glasshome/widget-sdk.git"
  },
  "homepage": "https://github.com/glasshome/widget-sdk#readme",
  "bugs": {
    "url": "https://github.com/glasshome/widget-sdk/issues"
  },
  "author": "GlassHome Labs",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
